{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "globals": {
    "KHub": "readonly"
  },
  "rules": {
    "no-console":      "warn",
    "no-unused-vars":  ["error", { "argsIgnorePattern": "^_" }],
    "eqeqeq":          ["error", "always"],
    "no-var":          "error",
    "prefer-const":    "error",
    "semi":            ["error", "always"],
    "quotes":          ["error", "single"],
    "indent":          ["error", 2],
    "no-trailing-spaces": "error",
    "eol-last":        ["error", "always"]
  }
}

